{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {},
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Read",
      "Edit",
      "Write",
      "Grep",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npx eslint *)",
      "Bash(npm install *)",
      "Bash(NODE_ENV=production LOG_LEVEL=info node -e ' *)",
      "Bash(NODE_ENV=development LOG_LEVEL=debug node -e ' *)",
      "Bash(curl -sS -o /tmp/pp-home.html -w \"HTTP %{http_code} %{size_download}B\\\\n\" http://localhost:3000)",
      "Bash(curl -sS -w \"\\\\nHTTP %{http_code}\\\\n\" \"http://localhost:3000/socket.io/?EIO=4&transport=polling\")",
      "Bash(curl -sS -i -X POST http://localhost:3000/api/rooms -H \"Content-Type: application/json\" -d '{\"scaleId\":\"fibonacci\",\"hostNickname\":\"Maria\"}')",
      "Bash(npx playwright *)",
      "Bash(npx prettier *)",
      "WebFetch(domain:kiarahdesign.myportfolio.com)",
      "Bash(echo \"started pid=$!\")",
      "Bash(lsof -ti:3000)",
      "Bash(xargs -r kill)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf /:*)"
    ]
  },
  "model": "claude-opus-4-7"
}
